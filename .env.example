# Qwen3-ASR environment
# Copy to .env and edit only the values you need to change.

# -----------------------------------------------------------------------------
# Public endpoint and auth.
# -----------------------------------------------------------------------------
# NGINX_PORT controls the host port used by docker-compose.
NGINX_PORT=17003

# Leave empty to disable authentication.
# API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# Runtime selection.
# -----------------------------------------------------------------------------
# CUDA_VISIBLE_DEVICES=0

# Leave QWEN3_ASR_MODEL empty for automatic selection.
# Supported values: qwen3-asr-0.6b, qwen3-asr-1.7b, mega-asr-1.7b
# -----------------------------------------------------------------------------
# DEVICE=auto
# QWEN3_ASR_MODEL=

# -----------------------------------------------------------------------------
# Mega-ASR Robust Model Configurations
# -----------------------------------------------------------------------------
# MEGA_ASR_LORA_PATH=ckpt/Mega-ASR/lora/adapter_model.safetensors
# MEGA_ASR_ROUTER_PATH=ckpt/Mega-ASR/router/model.safetensors
# MEGA_ASR_DEGRADED_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Model cache behavior.
# Default: download missing models at startup.
# Set HF_HUB_LOCAL_FILES_ONLY=1 only for prepared, strictly offline deployments.
# -----------------------------------------------------------------------------
HF_HUB_LOCAL_FILES_ONLY=0
# HF_ENDPOINT=https://hf-mirror.com

# -----------------------------------------------------------------------------
# Voiceprint identification.
# Enabled by default. DB path is persisted by docker-compose through ./data.
# Tune the threshold only after validating your own audio samples.
# -----------------------------------------------------------------------------
VOICEPRINT_ENABLED=true
VOICEPRINT_DB_PATH=./data/voiceprints.sqlite3
VOICEPRINT_MATCH_THRESHOLD=0.70

# -----------------------------------------------------------------------------
# Common optional overrides.
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# MAX_AUDIO_SIZE=2GB
# ASR_BATCH_SIZE=4
# MAX_SEGMENT_SEC=60
