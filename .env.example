# Qwen3-ASR environment overrides
# Copy to .env and uncomment only the values you need to change.

# -----------------------------------------------------------------------------
# Required only when you want API-key auth.
# -----------------------------------------------------------------------------
# API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# Docker / deployment entrypoint.
# -----------------------------------------------------------------------------
# NGINX_PORT=17003
# CUDA_VISIBLE_DEVICES=0
# NGINX_RATE_LIMIT_RPS=0
# NGINX_RATE_LIMIT_BURST=0

# -----------------------------------------------------------------------------
# Runtime model selection.
# Leave QWEN3_ASR_MODEL empty for automatic selection.
# Supported values: qwen3-asr-0.6b, qwen3-asr-1.7b
# -----------------------------------------------------------------------------
# DEVICE=auto
# QWEN3_ASR_MODEL=qwen3-asr-0.6b

# -----------------------------------------------------------------------------
# Model download/cache behavior.
# Default: download missing models at startup.
# Set HF_HUB_LOCAL_FILES_ONLY=1 only for prepared, strictly offline deployments.
# -----------------------------------------------------------------------------
# HF_HUB_LOCAL_FILES_ONLY=1
# HF_HUB_OFFLINE=1
# HF_ENDPOINT=https://hf-mirror.com
# HF_HOME=/root/.cache/huggingface
# MODELSCOPE_PATH=/root/.cache/modelscope/hub/models

# -----------------------------------------------------------------------------
# CPU Rust backend override.
# Usually unnecessary; auto-detect checks vendor/qwenasr/target/{release,debug}.
# -----------------------------------------------------------------------------
# QWENASR_LIBRARY_PATH=/absolute/path/to/libqwen_asr.so

# -----------------------------------------------------------------------------
# Tuning knobs & vLLM memory compression.
# -----------------------------------------------------------------------------
# ASR_BATCH_SIZE=4
# MAX_SEGMENT_SEC=60
# QWEN_RUST_CPU_WORKERS=4
# QWEN_RUST_ASR_CONCURRENCY=0
# QWEN_RUST_ALIGN_CONCURRENCY=0
# QWEN_GPU_MEMORY_UTILIZATION=0.08
# QWEN_FORCE_ALIGNER_GPU_MEMORY_UTILIZATION=0.15
# ASR_ENABLE_NEARFIELD_FILTER=true
# ASR_NEARFIELD_RMS_THRESHOLD=0.01

# vLLM low-VRAM memory compression configurations (extremely useful for 0.6B)
# VLLM_WORKER_MULTIPROC_METHOD=spawn
# VLLM_MAX_MODEL_LEN=2048
# VLLM_DISABLE_COMPILE_CACHE=1
# VLLM_DISABLE_CUDA_GRAPHS=1
# VLLM_USE_CUDA_GRAPHS=0
# VLLM_MAX_NUM_SEQS=1
# VLLM_ENFORCE_EAGER=1
# VLLM_TORCH_COMPILE_LEVEL=0

# -----------------------------------------------------------------------------
# Local development only.
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# FUNASR_STARTUP_UI=auto
